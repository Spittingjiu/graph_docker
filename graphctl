#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$PROJECT_DIR"

cmd="${1:-help}"

case "$cmd" in
  up)
    docker compose up -d
    ;;
  down)
    docker compose down
    ;;
  logs)
    docker compose logs -f --tail="${2:-100}"
    ;;
  auth)
    docker compose run --rm ms_graph_docker python3 /app/auth_cli.py
    ;;
  tenant-init)
    if [[ -z "${GRAPH_BOOTSTRAP_TOKEN:-}" ]]; then
      echo "请先导出 GRAPH_BOOTSTRAP_TOKEN（具备 Graph 应用管理权限）"
      echo "例如: export GRAPH_BOOTSTRAP_TOKEN='eyJ...'"
      exit 1
    fi
    docker compose run --rm -e GRAPH_BOOTSTRAP_TOKEN="$GRAPH_BOOTSTRAP_TOKEN" ms_graph_docker python3 /app/tenant_init.py
    ;;
  check)
    echo "[check] compose config"
    docker compose config >/dev/null && echo "OK"

    echo "[check] dns + token endpoint (container)"
    docker compose run --rm ms_graph_docker sh -lc "python3 - <<'PY'
import requests
try:
    r = requests.get('https://login.microsoftonline.com/common/discovery/v2.0/keys', timeout=10)
    print('token endpoint reachable:', r.status_code)
except Exception as e:
    print('token endpoint failed:', repr(e))
    raise
PY"

    echo "[check] container status"
    docker compose ps
    ;;
  help|*)
    cat <<'EOF'
用法: ./graphctl <command>

commands:
  up          启动容器
  down        停止容器
  logs        查看日志（默认100行，支持: ./graphctl logs 200）
  auth        运行首次授权向导（替代 rclone）
  tenant-init 自动创建应用与 .env（需 GRAPH_BOOTSTRAP_TOKEN）
  check       运行自检（网络/容器）
EOF
    ;;
esac
