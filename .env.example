# 时区
TZ=Asia/Shanghai

# 可选：Telegram 通知（两者同时填写才会发）
TG_BOT_TOKEN=
TG_SEND_ID=

# Microsoft Entra 应用配置（必填）
CLIENT_ID=
CLIENT_SECRET=

# 租户：默认 common（个人/多租户都可）
TENANT_ID=common

# 首次可留空，先跑 ./graphctl auth 自动写 token.txt
TOKEN_FIRST=

# 可选：Telegram 反代域名，不填或 null 走官方 api.telegram.org
PROXY_URL=null

# 可选：true 则调用补充 API（需要额外权限）
IS_API_URLS_EXTEND=false

# API 调用模式：lite(推荐) / full
GRAPH_API_PROFILE=lite

# 高级：自定义 API（逗号分隔），会覆盖 profile
# GRAPH_APIS=/me,/me/drive

# OAuth 配置（一般不用改）
REDIRECT_URI=http://localhost:53682/
AUTH_SCOPES=offline_access openid profile User.Read

# 请求超时（秒）
REQUEST_TIMEOUT=15

# 循环参数（自己用建议低噪）
CYCLE_MIN=3
CYCLE_MAX=5
API_SLEEP_MIN=3
API_SLEEP_MAX=6
LOOP_SLEEP_MIN=20
LOOP_SLEEP_MAX=40
